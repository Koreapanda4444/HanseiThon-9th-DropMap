{
  "name": "beoril-map-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "data:check": "tsx src/data-import/cli.ts --dry-run --skip-geocoding",
    "data:import": "tsx src/data-import/cli.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "oracledb": "^6.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/oracledb": "^7.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
